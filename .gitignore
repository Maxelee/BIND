# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Large caches & run outputs (regenerable; kept on disk, never versioned)
# ---------------------------------------------------------------------------
analysis_physics_cache/
analysis_physics_cache
*_cache/
outputs/

# ---------------------------------------------------------------------------
# Generated numerical data products (numpy dumps, etc.)
# ---------------------------------------------------------------------------
*.npz
*.npy
# Allow the bundled demo input + bundled package assets.
!examples/data/dmo_sample.npz
!src/bind/assets/*

# ---------------------------------------------------------------------------
# Run logs
# ---------------------------------------------------------------------------
*.log

# ---------------------------------------------------------------------------
# Generated figures. Existing committed figures stay tracked; new figures
# (and the figure directories below) are kept on disk but not versioned.
# ---------------------------------------------------------------------------
*.pdf
*.png
*.gif
figures/
figures
paper_figures/
paper_figures
paper_figures_thermo/
paper_figures_thermo
*_figs/
*_figs
imgs

# ---------------------------------------------------------------------------
# Downloaded papers / extracted scratch
# ---------------------------------------------------------------------------
aa53256-24.txt

# ---------------------------------------------------------------------------
# File / notebook backups
# ---------------------------------------------------------------------------
*.bak_pre_*
*.BACKUP.ipynb

# ---------------------------------------------------------------------------
# Machine-local config
# ---------------------------------------------------------------------------
.claude/settings.local.json

# ---------------------------------------------------------------------------
# Stale / scratch large artifacts (kept on disk, never versioned)
# ---------------------------------------------------------------------------
stale/

# ---------------------------------------------------------------------------
# Downloaded pretrained checkpoints (fetched via tools/download_weights.py)
# ---------------------------------------------------------------------------
weights/

# ---------------------------------------------------------------------------
# OS / editor
# ---------------------------------------------------------------------------
.DS_Store
